# AgentShield environment configuration
# Copy this file to `.env` and fill in values. NEVER commit your real .env.
# The entire firewall + judge run deterministically WITHOUT any of these set.
# These only enable the OPTIONAL live-LLM (Gemini) code paths.

# --- Optional: Google Gemini integration ---
# NOTE ON DATA EGRESS: enabling the LLM paths below sends the text being inspected
# (which may include untrusted content) to Google's Gemini API for a second
# opinion. Leave these unset to run 100% locally with no data leaving the machine.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Model used by the optional LLM judge / detector wrappers.
GEMINI_MODEL=gemini-2.5-flash

# Set to "true" to let the JudgeAgent call Gemini instead of the
# deterministic rubric judge. Defaults to deterministic when unset/false.
AGENTSHIELD_USE_LLM_JUDGE=false

# Set to "true" to let the InjectionDetectorAgent add an LLM second opinion
# on top of the deterministic pattern rules. Defaults to deterministic.
AGENTSHIELD_USE_LLM_DETECTOR=false

# --- Fail-closed input-size limits (block over-limit input; do not truncate) ---
AGENTSHIELD_MAX_USER_INPUT_CHARS=8000
AGENTSHIELD_MAX_ATTACHMENT_CHARS=50000
AGENTSHIELD_MAX_TOOL_RESPONSE_CHARS=20000
AGENTSHIELD_MAX_TOTAL_CONTEXT_CHARS=100000
AGENTSHIELD_MAX_API_BODY_BYTES=262144
